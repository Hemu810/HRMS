<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS deployment config for Doloxe HRMS backend (FastAPI + uvicorn).

  Prerequisites on the Windows server:
    1. Install IIS with the HttpPlatformHandler module
       (Download: https://www.iis.net/downloads/microsoft/httpplatformhandler)
    2. Create a Python 3.11 virtual environment in the backend folder:
         cd C:\inetpub\wwwroot\hr-app\backend
         python -m venv .venv
         .venv\Scripts\pip install -r requirements.txt
    3. Create a backend\.env file with your production env vars
       (DATABASE_URL, SMTP_*, FRONTEND_ORIGIN, etc.)
    4. Create the logs\ subfolder (IIS app-pool identity must have write access):
         mkdir C:\inetpub\wwwroot\hr-app\backend\logs

  IIS site setup:
    - Point the IIS Application physical path to this backend\ folder.
    - Application Pool: No Managed Code (Unmanaged), Integrated pipeline.
    - Give the app-pool identity read+write on the backend\ folder
      (needed for SQLite file, uploads\, and logs\).
-->
<configuration>
  <system.webServer>

    <handlers>
      <!-- Remove any existing handler for all verbs/paths, then add ours. -->
      <remove name="PythonFastAPIHandler" />
      <add name="PythonFastAPIHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <!--
      HttpPlatformHandler starts uvicorn as a child process and reverse-proxies
      all IIS traffic to it.  %HTTP_PLATFORM_PORT% is injected at runtime by IIS
      so the port is never hardcoded.
    -->
    <httpPlatform processPath=".venv\Scripts\python.exe"
                  arguments="-m uvicorn app:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT% --workers 2"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\uvicorn.log"
                  startupTimeLimit="120"
                  startupRetryCount="3"
                  requestTimeout="00:04:00"
                  forwardWindowsAuthToken="false">
      <environmentVariables>
        <!-- Map IIS-assigned port to the same name the app reads. -->
        <environmentVariable name="PORT"  value="%HTTP_PLATFORM_PORT%" />
        <!-- Bind to loopback — IIS is the public-facing listener. -->
        <environmentVariable name="HOST"  value="127.0.0.1" />
        <!-- Keep Python from buffering stdout so logs appear immediately. -->
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
        <!--
          Add any other env vars here, or put them in backend\.env:
          <environmentVariable name="FRONTEND_ORIGIN" value="https://your-iis-site.com" />
          <environmentVariable name="DATABASE_URL"    value="mssql+pymssql://..." />
        -->
      </environmentVariables>
    </httpPlatform>

  </system.webServer>
</configuration>
