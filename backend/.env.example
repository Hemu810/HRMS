# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
RELOAD=false

# URL of the deployed frontend (for CORS). Use exact origin including protocol.
FRONTEND_ORIGIN=https://your-frontend.vercel.app

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — full connection string (takes priority over individual vars below)
# SQLite (local dev):
# DATABASE_URL=sqlite:///./doloxe_hrms_dev.db
# MSSQL via pymssql (Render / Linux):
# DATABASE_URL=mssql+pymssql://username:password@host/DOLOXE_DEV
# MSSQL via pyodbc (IIS / Windows):
# DATABASE_URL=mssql+pyodbc://username:password@host/DOLOXE_DEV?driver=ODBC+Driver+17+for+SQL+Server

# Option B — individual vars (auto-builds a pymssql URL)
DB_SERVER=your-sql-server-host-or-ip
DB_DATABASE=DOLOXE_DEV
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# ── SMTP (email delivery) ─────────────────────────────────────────────────────
# For Gmail: enable 2FA → generate an App Password at
#   myaccount.google.com/apppasswords
# Do NOT use your normal Gmail login password here.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=DOLOXE Finance Operations <your-email@gmail.com>

# ── Seed passwords (used only by setup_db.py) ─────────────────────────────────
# Change these before running setup_db.py in production.
SEED_PASS_DIRECTOR=change-me-director
SEED_PASS_MANAGER=change-me-manager
SEED_PASS_LEAD=change-me-lead
SEED_PASS_EMPLOYEE=change-me-employee
