# Environment files — never commit secrets
.env
.env.*
!.env.example

# SQLite dev database
backend/*.db

# Python bytecode — never commit, differs per Python version
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
