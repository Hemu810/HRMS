# ── API URL ───────────────────────────────────────────────────────────────────
# URL of the deployed backend. Baked into the JS bundle at build time.
# For local dev this defaults to http://localhost:4000 if not set.
VITE_API_URL=https://your-backend.onrender.com

# ── Payslip email endpoint ────────────────────────────────────────────────────
# Must point to the same backend.
VITE_PAYSLIP_EMAIL_ENDPOINT=https://your-backend.onrender.com/api/send-payslip
